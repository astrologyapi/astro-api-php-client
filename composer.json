{
    "name": "astrologyapi/astrologyapi-php",
    "version": "2.0.0",
    "description": "Official PHP SDK for AstrologyAPI.com — Vedic, Western, KP, Lal Kitab, Numerology, and more.",
    "type": "library",
    "license": "MIT",
    "keywords": ["astrology", "vedic", "horoscope", "kundli", "panchang", " numerology"],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "psr/http-message": "^1.0 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "guzzlehttp/psr7": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "AstrologyAPI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AstrologyAPI\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src"
    }
}
